
# LLM Provider: "ollama" or "gemini"
LLM_PROVIDER=gemini

# For Ollama (local models)
OLLAMA_NAMES=qwen2.5-coder:3b,gemma2:2b
OLLAMA_TEMPERATURES=0.1,0.1

# For Gemini API
GOOGLE_API_KEY=---api-key---
GEMINI_MODELS=gemini-2.5-pro
GEMINI_TEMPERATURES=0.1

# MAX_REFINEMENTS: Number of times each agent can refine their code when self-tests fail
# Recommended: 3 to allow sufficient refinement attempts
MAX_REFINEMENTS=3

# MAX_CROSS_REFINEMENTS: Number of times each agent can refine against the combined test suite
# Defaults to MAX_REFINEMENTS if not set
MAX_CROSS_REFINEMENTS=3

WORKSPACE_DIR=workspace
TASK_IDS=OOP/54,OOP/152,OOP/106,OOP/162,OOP/154,OOP/163,OOP/90,OOP/16,OOP/68,OOP/150,OOP/76,OOP/96,OOP/94,OOP/35,OOP/156,OOP/98,OOP/50,OOP/74,OOP/38,OOP/105,OOP/37,OOP/53,OOP/69,OOP/28,OOP/77

NUM_BATCH_EXECUTIONS=3
# Experiment configuration
FEEDBACK_MODE=passing
MUTPY_TIMEOUT=120
TREATMENT_NAME=passing.single-model
